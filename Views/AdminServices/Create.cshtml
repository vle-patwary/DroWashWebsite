@model DroWashWebsite.Models.Service
@{
    ViewData["Title"] = "Add Service";
    Layout = "_AdminLayout";
}

<div class="admin-page-head">
    <div>
        <h1>Add Service</h1>
        <p>This will appear as a new card in the "What We Fly" section.</p>
    </div>
</div>

<div class="admin-panel">
    <form asp-action="Create" method="post" class="admin-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="admin-alert admin-alert-error" style="@(ViewData.ModelState.IsValid ? "display:none;" : "")"></div>

        <div class="form-row">
            <label asp-for="Index">Index (e.g. 01, 02, 03)</label>
            <input asp-for="Index" placeholder="01" />
            <span asp-validation-for="Index" class="field-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="Title">Title</label>
            <input asp-for="Title" placeholder="High-Rise Window Cleaning" />
            <span asp-validation-for="Title" class="field-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="Description">Description</label>
            <textarea asp-for="Description" rows="3" placeholder="Short description shown under the title"></textarea>
            <span asp-validation-for="Description" class="field-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="IconSvgPath">Icon SVG path data</label>
            <textarea asp-for="IconSvgPath" rows="2" placeholder="&lt;rect x=&quot;6&quot; y=&quot;2&quot; width=&quot;12&quot; height=&quot;20&quot; rx=&quot;1&quot;/&gt;..."></textarea>
            <span asp-validation-for="IconSvgPath" class="field-error"></span>
        </div>

        <div class="form-row">
            <label asp-for="SortOrder">Sort order (lower numbers show first)</label>
            <input asp-for="SortOrder" type="number" placeholder="1" />
            <span asp-validation-for="SortOrder" class="field-error"></span>
        </div>

        <div class="admin-form-actions">
            <button type="submit" class="btn btn-primary">Save Service</button>
            <a asp-action="Index" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
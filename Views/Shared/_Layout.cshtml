<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>@ViewData["Title"] - DroWash Drone Services Inc.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="~/css/site.css" asp-append-version="true">
<style>
  .staff-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: .04em;
    text-transform: uppercase;
    color: #7f9cbf;
    text-decoration: none;
    padding: 7px 12px;
    border: 1px solid rgba(127, 156, 191, .35);
    border-radius: 999px;
    transition: color .15s ease, border-color .15s ease, background .15s ease;
  }

  .staff-link:hover {
    color: #3fd0ff;
    border-color: #3fd0ff;
    background: rgba(63, 208, 255, .08);
  }

  .staff-link svg {
    flex-shrink: 0;
  }

  @@media (max-width: 640px) {
    .staff-link .staff-label {
      display: none;
    }

    .staff-link {
      padding: 8px;
    }
  }
</style>
</head>
<body>
<header>
  <div class="wrap header-inner">
    <a href="~/" class="brand">
      <img src="~/images/logo.jpg" alt="DroWash Drone Services Inc. logo">
      <div class="brand-text">
        <span class="name">DroWash</span>
        <span class="tag">Drone Services Inc.</span>
      </div>
    </a>
    <nav class="main-nav" id="mainNav">
      <a href="#services">Services</a>
      <a href="#process">Process</a>
      <a href="#deionized">Why Deionized</a>
      <a href="#why-drowash">Why DroWash</a>
      <a href="#contact">Contact</a>
    </nav>
    <div class="header-actions">
      <a href="~/Account/Login" class="staff-link" title="Staff and crew access only">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" width="13" height="13">
          <rect x="5" y="11" width="14" height="9" rx="2"/>
          <path d="M8 11V7a4 4 0 0 1 8 0v4"/>
        </svg>
        <span class="staff-label">Flight Deck</span>
      </a>
      <a href="#contact" class="btn btn-primary">Get A Quote</a>
      <button class="menu-toggle" id="menuToggle" aria-label="Toggle menu" aria-expanded="false" aria-controls="mainNav">
        <span class="menu-toggle-bars">
          <span></span><span></span><span></span>
        </span>
      </button>
    </div>
  </div>
  <div class="nav-overlay" id="navOverlay"></div>
</header>
<main>
  @RenderBody()
</main>
<footer>
  <div class="wrap">
    <div class="footer-grid">
      <div>
        <div class="footer-brand">
          <img src="~/images/logo.jpg" alt="DroWash logo">
          <span>DroWash</span>
        </div>
        <p style="font-size:13.5px; line-height:1.6; max-width:280px;">Drone-based exterior cleaning for commercial and residential properties. Safer. Faster. Cleaner. Smarter.</p>
      </div>
      <div>
        <h5>Services</h5>
        <ul>
          <li><a href="#services">Facade Washing</a></li>
          <li><a href="#services">Solar Panel Cleaning</a></li>
          <li><a href="#services">Roof &amp; Gutter</a></li>
          <li><a href="#services">Window Detailing</a></li>
        </ul>
      </div>
      <div>
        <h5>Company</h5>
        <ul>
          <li><a href="#process">Our Process</a></li>
          <li><a href="#why-drowash">Why DroWash</a></li>
          <li><a href="#deionized">Our Technology</a></li>
        </ul>
      </div>
      <div>
        <h5>Contact</h5>
        <ul>
                        <li><a href="mailto:info@drowash.com">info@drowash.com</a></li>
          <li><a href="tel:+18005551234">(800) 000-0000</a></li>
          <li>Mon&ndash;Sat, 7am&ndash;6pm</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>&copy; 2026 DroWash Drone Services Inc. All rights reserved.</span>
      <span style="font-family:var(--font-mono); letter-spacing:.06em;">SAFER &middot; FASTER &middot; CLEANER &middot; SMARTER</span>
    </div>
  </div>
</footer>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
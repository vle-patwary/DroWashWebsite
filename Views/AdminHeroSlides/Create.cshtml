@{
    ViewData["Title"] = "Add Slide";
    Layout = "_AdminLayout";
}

<div class="admin-page-head">
    <div>
        <h1>Add Hero Slide</h1>
        <p>Upload a new image for the homepage hero slideshow.</p>
    </div>
</div>

<div class="admin-panel">
    <form asp-action="Create" method="post" enctype="multipart/form-data" class="admin-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="admin-alert admin-alert-error" style="@(ViewData.ModelState.IsValid ? "display:none;" : "")"></div>

        <div class="form-row">
            <label for="imageFile">Image file (.jpg, .jpeg, .png, .webp — max 5 MB)</label>
            <input type="file" id="imageFile" name="imageFile" accept=".jpg,.jpeg,.png,.webp" required />
        </div>

        <div class="form-row">
            <label for="sortOrder">Sort order (lower numbers show first)</label>
            <input type="number" id="sortOrder" name="sortOrder" value="1" />
        </div>

        <div class="admin-form-actions">
            <button type="submit" class="btn btn-primary">Upload Slide</button>
            <a asp-action="Index" class="btn btn-outline">Cancel</a>
        </div>
    </form>
</div>
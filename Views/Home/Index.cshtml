@model HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<section class="hero" id="top">
  <div class="wrap hero-grid">
    <div>
      <div class="eyebrow"><span class="dot"></span> No rigs. No ropes. No rooftop crews.</div>
      <h1>Building exteriors, cleaned from the <span>air</span>.</h1>
      <p class="lead">DroWash flies deionized-water drone systems across facades, glass, solar arrays and rooftops &mdash; cutting cleaning time, cost and risk versus a traditional rope-access crew.</p>
      <div class="hero-cta">
        <a href="#contact" class="btn btn-primary">Get A Quote</a>
        <a href="#process" class="btn btn-ghost">See how it works &darr;</a>
      </div>
      <div class="hero-stats">
        <div><div class="num">0</div><div class="lbl">Rope Access Crew</div></div>
        <div><div class="num">100%</div><div class="lbl">Deionized Water</div></div>
        <div><div class="num">3x</div><div class="lbl">Faster Turnaround</div></div>
      </div>
    </div>

    <div class="hero-slideshow" id="heroSlideshow">
      @if (Model.HeroSlides.Any())
      {
        for (int i = 0; i < Model.HeroSlides.Count; i++)
        {
          <div class="slide @(i == 0 ? "active" : "")" style="background-image:url('@Url.Content(Model.HeroSlides[i])')"></div>
        }
        <div class="slide-overlay"></div>
        @if (Model.HeroSlides.Count > 1)
        {
          <button class="slide-arrow prev" id="slidePrev" aria-label="Previous slide">&#8249;</button>
          <button class="slide-arrow next" id="slideNext" aria-label="Next slide">&#8250;</button>
          <div class="slide-dots" id="slideDots">
            @for (int i = 0; i < Model.HeroSlides.Count; i++)
            {
              <button class="dot @(i == 0 ? "active" : "")" data-index="@i" aria-label="Go to slide @(i + 1)"></button>
            }
          </div>
        }
      }
      else
      {
        <div class="slide-placeholder">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" width="40" height="40">
            <rect x="3" y="4" width="18" height="14" rx="2"/><circle cx="8.5" cy="9.5" r="1.5"/><path d="M21 15l-5-5-4 4-3-3-5 5"/>
          </svg>
          <p>Add project photos to<br><code>wwwroot/images/hero-slideshow/</code><br>named <code>slide-1.jpg</code>, <code>slide-2.jpg</code>&hellip; to show them here.</p>
        </div>
      }
    </div>
  </div>
</section>

<section class="services" id="services">
  <div class="wrap">
    <div class="section-head">
      <span class="kicker">What We Fly</span>
      <h2>One drone fleet, fifteen ways to clean a property.</h2>
      <p>At DroWash, we combine advanced drone technology with deionized (DI) purified water to serve commercial office towers, condominiums, hotels, hospitals, universities, industrial facilities, shopping centres and high-rise residential buildings throughout Ontario.</p>
    </div>

    <div class="service-grid">
      @foreach (var service in Model.Services)
      {
        <div class="service-card">
          <span class="idx">@service.Index</span>
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">@Html.Raw(service.IconSvgPath)</svg>
          <h3>@service.Title</h3>
          <p>@service.Description</p>
        </div>
      }
    </div>

    @if (Model.AdditionalServices.Any())
    {
      <div class="additional-services">
        <h4>Additional Services</h4>
        <div class="tag-cloud">
          @foreach (var tag in Model.AdditionalServices)
          {
            <span class="tag-chip">@tag</span>
          }
        </div>
      </div>
    }
  </div>
</section>



<section class="process" id="process">
  <div class="wrap">
    <div class="section-head on-dark">
      <span class="kicker">Client Onboarding</span>
      <h2>From first call to finished facade in five steps.</h2>
    </div>

    <div class="process-track">
      @foreach (var step in Model.ProcessSteps)
      {
        <div class="process-step">
          <div class="node">@step.Number</div>
          <h4>@step.Title</h4>
          <p>@step.Description</p>
        </div>
      }
    </div>
  </div>
</section>

<section class="alt">
  <div class="wrap">
    <div class="section-head center" style="margin-left:auto;margin-right:auto;">
      <span class="kicker">Proof, Not Promises</span>
      <h2>Cheaper and faster than a rope-access crew.</h2>
      <p>Drag the handle &mdash; same building, same day.</p>
    </div>

    <div class="compare-wrap" id="compareWrap">
      <div class="layer after">
        @if (!string.IsNullOrEmpty(Model.AfterImageUrl))
        {
          <img src="@Url.Content(Model.AfterImageUrl)" alt="After DroWash cleaning" draggable="false">
        }
        else
        {
          <div class="facade">
            @for (int i = 0; i < 60; i++) { <div></div> }
          </div>
        }
      </div>
      <div class="layer before">
        @if (!string.IsNullOrEmpty(Model.BeforeImageUrl))
        {
          <img src="@Url.Content(Model.BeforeImageUrl)" alt="Before DroWash cleaning" draggable="false">
        }
        else
        {
          <div class="facade">
            @for (int i = 0; i < 60; i++) { <div></div> }
          </div>
        }
      </div>
      <span class="compare-label l">Before</span>
      <span class="compare-label r">After</span>
      <div class="compare-handle" id="compareHandle">
        <div class="grip">&harr;</div>
      </div>
    </div>
    @if (string.IsNullOrEmpty(Model.BeforeImageUrl) || string.IsNullOrEmpty(Model.AfterImageUrl))
    {
      <p class="compare-hint">Drop <code>before.jpg</code> and <code>after.jpg</code> into <code>wwwroot/images/before-after/</code> to show real photos here.</p>
    }
  </div>
</section>

<section class="tint" id="deionized">
  <div class="wrap">
    <div class="feature-row">
      <div class="col-text">
        <span class="kicker">Why Deionized Water</span>
        <h2 class="feature-heading">Zero minerals in, zero streaks left behind.</h2>
        <ul class="feature-list">
          @foreach (var item in Model.DeionizedFeatures)
          {
            <li>
              <span class="num">@item.Number</span>
              <div><h4>@item.Title</h4><p>@item.Description</p></div>
            </li>
          }
        </ul>
      </div>
            <div class="col-visual">
                <div class="dw-card dw-observe" id="dwCard1">
                    <div class="dw-ripple"></div>
                    <div class="dw-ripple"></div>
                    <div class="dw-ripple"></div>

                    <div class="dw-gauge-wrap">
                        <div class="dw-gauge">
                            <svg width="100%" height="100%" viewBox="0 0 132 132">
                                <defs>
                                    <linearGradient id="dwGaugeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                                        <stop offset="0%" stop-color="#2e8fe6" />
                                        <stop offset="100%" stop-color="#5fb4ff" />
                                    </linearGradient>
                                </defs>
                                <circle class="dw-gauge-track" cx="66" cy="66" r="54" fill="none" stroke-width="8" />
                                <circle class="dw-gauge-fill" id="dwGaugeFill" cx="66" cy="66" r="54" fill="none" stroke-width="8" />
                            </svg>
                            <div class="dw-gauge-center">
                                <div class="dw-gauge-num" id="dwPpmNum">100</div>
                                <div class="dw-gauge-unit">PPM</div>
                            </div>
                        </div>
                        <div>
                            <div class="dw-gauge-label">Live Reading</div>
                            <div class="dw-gauge-title">Total Dissolved Solids</div>
                            <div class="dw-gauge-sub">Purified in real time, stage by stage, to zero.</div>
                        </div>
                    </div>

                    <div class="dw-mini-stats">
                        <div>
                            <div class="dw-num" data-target="18">0</div>
                            <div class="dw-lab">Resistivity (MΩ)</div>
                            <div class="dw-bar"><i data-width="90"></i></div>
                        </div>
                        <div>
                            <div class="dw-num" data-target="100">0</div>
                            <div class="dw-lab">Streak-Free</div>
                            <div class="dw-bar"><i data-width="100"></i></div>
                        </div>
                        <div>
                            <div class="dw-num" data-target="50" data-suffix="+">0</div>
                            <div class="dw-lab">Stories Serviced</div>
                            <div class="dw-bar"><i data-width="75"></i></div>
                        </div>
                    </div>
                </div>
            </div>
    </div>
  </div>
</section>

<section class="alt">
  <div class="wrap">
    <div class="feature-row rev">
            <div class="col-visual">
                <div class="dw-card dw-observe" id="dwCard2">
                    <div>
                        <div class="dw-speed-num"><span data-target="3" data-suffix="x">0x</span></div>
                        <div class="dw-gauge-label" style="margin-top:8px;">Faster Than Rope Access</div>

                        <div class="dw-compare">
                            <div class="dw-compare-row">
                                <div class="dw-rlabel"><span>Rope access</span><span>100%</span></div>
                                <div class="dw-track"><div class="dw-fill rope" data-width="100"></div></div>
                            </div>
                            <div class="dw-compare-row">
                                <div class="dw-rlabel"><span>Water-fed drone</span><span>33%</span></div>
                                <div class="dw-track"><div class="dw-fill pole" data-width="33"></div></div>
                            </div>
                        </div>
                    </div>

                    <div class="dw-end-stats">
                        <div><div class="dw-num down">&darr; Cost</div><div class="dw-lab">No Rigging Crew</div></div>
                        <div><div class="dw-num up">&uarr; Value</div><div class="dw-lab">Property Upkeep</div></div>
                    </div>
                </div>
            </div>
      <div class="col-text">
        <span class="kicker">Benefits Of Streak-Free Cleaning</span>
        <h2 class="feature-heading">A cleaner finish protects the asset, not just the view.</h2>
        <ul class="feature-list">
          @foreach (var item in Model.StreakFreeFeatures)
          {
            <li>
              <span class="num">@item.Number</span>
              <div><h4>@item.Title</h4><p>@item.Description</p></div>
            </li>
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<section id="why-drowash">
  <div class="wrap">
    <div class="section-head">
      <span class="kicker">Why DroWash Cleaners</span>
      <h2>Built for facility managers who can't afford downtime.</h2>
    </div>

    <div class="why-grid">
      @foreach (var card in Model.WhyCards)
      {
        <div class="why-card">
          <svg class="icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">@Html.Raw(card.IconSvgPath)</svg>
          <h4>@card.Title</h4>
          <p>@card.Description</p>
        </div>
      }
    </div>
  </div>
</section>

<section class="quote-section" id="contact">
  <div class="wrap quote-grid">
    <div class="quote-intro">
      <span class="kicker">Get A Quote</span>
      <h2>Ready to see your property clean from the air?</h2>
      <p>Send us your building details and we'll come back with a fixed quote and a proposed flight date.</p>
            <a href="tel:+1 289-780-9647" class="btn btn-ghost" style="border-color:rgba(255,255,255,.25); margin-top:8px;">Or call (+1 289-780-9647) </a>
    </div>

    <div class="quote-card">
      <form id="quoteForm" novalidate>
        @Html.AntiForgeryToken()

        <div class="form-row">
          <label for="FullName">Full name</label>
          <input type="text" id="FullName" name="FullName" placeholder="Jane Cooper" autocomplete="name">
          <span class="field-error" data-for="FullName"></span>
        </div>

        <div class="form-row two-col">
          <div>
            <label for="Email">Email</label>
            <input type="email" id="Email" name="Email" placeholder="jane@company.com" autocomplete="email">
            <span class="field-error" data-for="Email"></span>
          </div>
          <div>
            <label for="Phone">Phone</label>
            <input type="tel" id="Phone" name="Phone" placeholder="(800) 555-1234" autocomplete="tel">
            <span class="field-error" data-for="Phone"></span>
          </div>
        </div>

        <div class="form-row">
          <label for="PropertyAddress">Property address</label>
          <input type="text" id="PropertyAddress" name="PropertyAddress" placeholder="123 Main St, City, State">
          <span class="field-error" data-for="PropertyAddress"></span>
        </div>

        <div class="form-row">
          <label for="PropertyType">Property type</label>
          <select id="PropertyType" name="PropertyType">
            <option value="">Select one</option>
            <option value="Residential">Residential</option>
            <option value="Commercial">Commercial</option>
            <option value="High-Rise">High-Rise</option>
            <option value="Industrial">Industrial</option>
          </select>
          <span class="field-error" data-for="PropertyType"></span>
        </div>

        <div class="form-row">
          <label for="Notes">Tell us about the job (optional)</label>
          <textarea id="Notes" name="Notes" rows="3" placeholder="Number of stories, problem areas, preferred timing..."></textarea>
        </div>

        <!-- Honeypot field: hidden from real visitors with CSS, left open for bots -->
        <div class="hp-field" aria-hidden="true">
          <label for="Website">Leave this field empty</label>
          <input type="text" id="Website" name="Website" tabindex="-1" autocomplete="off">
        </div>

        <span class="field-error" data-for="General"></span>

        <button type="submit" class="btn btn-primary" id="quoteSubmitBtn">Get A Quote</button>
      </form>

      <div class="quote-success" id="quoteSuccess" hidden>
        <h3>Request received.</h3>
        <p>Thanks<span id="quoteSuccessName"></span> &mdash; we'll be in touch within one business day with a fixed quote.</p>
      </div>
    </div>
  </div>
</section>
@section Scripts {
    <script>
        (function() {
            function animateDwCount(el) {
                const target = parseFloat(el.dataset.target);
                const suffix = el.dataset.suffix || '';
                const dur = 1400;
                const start = performance.now();
                function step(now) {
                    const p = Math.min((now - start) / dur, 1);
                    const eased = 1 - Math.pow(1 - p, 3);
                    el.textContent = Math.round(target * eased) + suffix;
                    if (p < 1) requestAnimationFrame(step);
                }
                requestAnimationFrame(step);
            }
            const featureItems = document.querySelectorAll('.feature-list li');
  const featureObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry, i) => {
      if (entry.isIntersecting) {
        setTimeout(() => entry.target.classList.add('dw-in-view'), (i * 90) % 400);
        featureObserver.unobserve(entry.target);
      }
    });
  }, { threshold: .2 });
  featureItems.forEach(el => featureObserver.observe(el));
            document.querySelectorAll('.dw-observe').forEach(el => {
                new IntersectionObserver((entries, obs) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add('dw-in-view');
                            obs.unobserve(entry.target);
                        }
                    });
                }, { threshold: .2 }).observe(el);
            });

            const dwCard1 = document.getElementById('dwCard1');
            if (dwCard1) {
                new IntersectionObserver((entries, obs) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            document.getElementById('dwGaugeFill').style.strokeDashoffset = '0';
                            document.getElementById('dwPpmNum').textContent = '0';
                            dwCard1.querySelectorAll('.dw-mini-stats .dw-num').forEach(animateDwCount);
                            dwCard1.querySelectorAll('.dw-bar i').forEach(b => b.style.width = b.dataset.width + '%');
                            obs.unobserve(entry.target);
                        }
                    });
                }, { threshold: .35 }).observe(dwCard1);
            }

            const dwCard2 = document.getElementById('dwCard2');
            if (dwCard2) {
                new IntersectionObserver((entries, obs) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            const speedEl = dwCard2.querySelector('.dw-speed-num span');
                            if (speedEl) animateDwCount(speedEl);
                            dwCard2.querySelectorAll('.dw-fill').forEach(b => b.style.width = b.dataset.width + '%');
                            obs.unobserve(entry.target);
                        }
                    });
                }, { threshold: .35 }).observe(dwCard2);
            }
        })();
    </script>
}